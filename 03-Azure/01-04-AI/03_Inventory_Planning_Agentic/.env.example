# Copy this file to `.env` and fill in the three values from your lab dashboard.
# The dashboard shows these after `labautomation/deploy-lab.ps1` provisions your lab.

# Foundry project endpoint (dashboard: FoundryProjectEndpoint)
PROJECT_ENDPOINT=https://inv-xxxxxxxxxxxx.services.ai.azure.com/api/projects/inventory-hack

# Model deployment name (dashboard: ModelDeploymentName)
MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# Per-attendee Cosmos DB endpoint (dashboard: CosmosEndpoint) — the governed data store
COSMOS_ENDPOINT=https://inv-cos-xxxxxxxxxxxx.documents.azure.com:443/
COSMOS_DATABASE=inventory

# Optional: set to true to attach the Web Search grounding tool in Challenge 1.
ENABLE_WEB_SEARCH=false

# Optional: reasoning budget for GPT-5 models. "minimal" keeps the planner console
# snappy (gpt-5.4-mini is a reasoning model). Options: minimal | low | medium |
# high | none | default. Use "default" to let the model decide.
REASONING_EFFORT=minimal
